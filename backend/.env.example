# ─── AI Layer ────────────────────────────────────────────────────────────────
DEMO_MODE=true
OLLAMA_URL=http://localhost:11434
HF_API_KEY=

# ─── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_MOCK=true
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_PROJECT_ID=

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default, zero config):
DATABASE_URL=sqlite:///./autodev_guardian.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/autodev

# ─── Authentication ──────────────────────────────────────────────────────────
# CRITICAL: change this in production! Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
JWT_EXPIRE_MINUTES=480
DEFAULT_ADMIN_PASSWORD=AdminPass123!

# ─── Security / CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_REQUEST_SIZE_BYTES=10485760

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console   # "json" for production log aggregators (Datadog, Loki, etc.)

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
